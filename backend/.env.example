# ============================================
# KEENEED 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================

# Server
PORT=3001
NODE_ENV=development

# JWT (生产环境必须设置，至少32字符随机字符串)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=keeneed

# Alibaba Cloud DirectMail
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIBABA_CLOUD_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
DIRECTMAIL_ACCOUNT_NAME=your-directmail-sender-email
DIRECTMAIL_FROM_ALIAS=KEENEED

# DeepSeek AI
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Admin
ADMIN_TOKEN=change-me-to-a-random-admin-token
